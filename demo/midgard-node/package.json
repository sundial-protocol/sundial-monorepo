{
  "name": "midgard-node",
  "version": "1.0.0",
  "description": "A CLI application for submitting/receiving L2 transactions and committing/merging Midgard blocks",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "midgard-node": "./dist/index.js"
  },
  "scripts": {
    "clean": "rimraf dist node_modules",
    "build": "tsup src/index.ts --minify --format esm && tsup src/workers/* --minify --format esm",
    "type-check": "pnpm exec tsc -p tsconfig.json --skipLibCheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "listen": "pnpm run build && node dist/index.js listen",
    "init": "pnpm run build && node dist/index.js init",
    "test": "NODE_ENV=emulator vitest run --config vitest.config.ts"
  },
  "keywords": [
    "cardano",
    "layer2",
    "midgard",
    "anastasia-labs"
  ],
  "author": "Anastasia Labs",
  "license": "ISC",
  "dependencies": {
    "@aiken-lang/merkle-patricia-forestry": "^1.3.1",
    "@al-ft/midgard-sdk": "workspace:*",
    "@effect/cluster": "^0.58.2",
    "@effect/experimental": "^0.60.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@effect/sql-pg": "^0.52.1",
    "@electric-sql/pglite": "^0.4.5",
    "@ethereumjs/mpt": "7.0.0-alpha.1",
    "@ethereumjs/util": "^9.1.0",
    "@harmoniclabs/crypto": "^0.3.0",
    "@lucid-evolution/lucid": "^0.4.30",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "effect": "^3.21.2",
    "level": "^10.0.0",
    "memory-level": "^3.1.0",
    "rimraf": "^6.1.3",
    "vitest": "3.2.4"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^13.1.0",
    "@effect/vitest": "^0.29.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.18",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "overrides": {
    "ip-address": "10.2.0",
    "@cardano-sdk/core": "0.46.12"
  }
}
