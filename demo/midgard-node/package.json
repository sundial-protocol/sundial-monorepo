{
  "name": "midgard-node",
  "version": "1.0.0",
  "description": "A CLI application for submitting/receiving L2 transactions and committing/merging Midgard blocks",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "midgard-node": "./dist/index.js"
  },
  "scripts": {
    "clean": "rimraf dist node_modules",
    "build": "tsup src/index.ts --minify --format esm && tsup src/workers/* --minify --format esm",
    "type-check": "pnpm exec tsc -p tsconfig.json --skipLibCheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "listen": "pnpm run build && node dist/index.js listen",
    "init": "pnpm run build && node dist/index.js init",
    "test": "export NODE_ENV='emulator' && vitest run -- --reporter=basic --disable-console-intercept"
  },
  "keywords": [
    "cardano",
    "layer2",
    "midgard",
    "anastasia-labs"
  ],
  "author": "Anastasia Labs",
  "license": "ISC",
  "dependencies": {
    "@aiken-lang/merkle-patricia-forestry": "^1.2.0",
    "@al-ft/midgard-sdk": "file:../midgard-sdk/al-ft-midgard-sdk-0.1.0.tgz",
    "@effect/experimental": "^0.45.1",
    "@effect/opentelemetry": "^0.44.6",
    "@effect/platform": "^0.81.1",
    "@effect/platform-node": "^0.79.0",
    "@effect/rpc": "^0.58.0",
    "@effect/cluster": "^0.32.0",
    "@effect/sql": "^0.34.1",
    "@effect/sql-pg": "^0.35.1",
    "@harmoniclabs/crypto": "^0.3.0",
    "@ethereumjs/mpt": "7.0.0-alpha.1",
    "@ethereumjs/util": "^9.1.0",
    "@lucid-evolution/lucid": "^0.4.29",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/sdk-trace-web": "^1.30.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "effect": "^3.14.22",
    "level": "^10.0.0",
    "memory-level": "^3.1.0",
    "rimraf": "^6.0.1",
    "vitest": "^3.0.7"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^13.1.0",
    "@effect/vitest": "^0.22.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.17.0",
    "prettier": "^3.5.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.5"
  },
  "pnpm": {
    "overrides": {
      "libsodium-wrappers-sumo": "0.7.15",
      "libsodium-sumo": "0.7.15"
    }
  }
}
