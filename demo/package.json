{
  "name": "midgard-l2",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "test": "vitest run --mode=test",
    "clean": "turbo clean && rm -rf node_modules",
    "install-sdk": "pnpm --filter midgard-sdk install",
    "repack-sdk": "pnpm --filter midgard-sdk repack"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "cross-env": "^7.0.3",
    "knip": "^5.88.1",
    "prettier": "^3.8.3",
    "turbo": "2.9.9",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "overrides": {
    "test-exclude": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "effect": "3.21.2",
      "test-exclude": "^8.0.0",
      "libsodium-wrappers-sumo": "0.7.15",
      "libsodium-sumo": "0.7.15",
      "@cardano-sdk/core": "0.46.12",
      "@cardano-sdk/crypto": "0.4.5",
      "ip-address": "10.2.0",
      "pbkdf2": "3.1.3",
      "sha.js": "2.4.12",
      "protobufjs@7": "7.5.6",
      "glob@10": "10.5.0",
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "rollup@4": "4.60.3",
      "flatted": "3.4.2",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "lodash": "4.18.1",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "ajv@6": "6.15.0",
      "js-yaml@4": "4.1.1",
      "postcss": "8.5.14",
      "@eslint/plugin-kit": "0.7.1",
      "diff@4": "4.0.4",
      "glob": "^13.0.6",
      "uuid": "^11.1.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@harmoniclabs/crypto": "0.2.5"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "cbor-extract",
      "classic-level",
      "esbuild",
      "msgpackr-extract",
      "protobufjs"
    ]
  }
}
