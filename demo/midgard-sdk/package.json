{
  "name": "@al-ft/midgard-sdk",
  "version": "0.1.0",
  "description": "https://docs.github.com/en/packages/quickstart",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "reset": "rimraf dist node_modules *.tgz",
    "build": "tsup src/index.ts --minify --format esm,cjs --dts --clean",
    "type-check": "tsc --noEmit -p tsconfig.quality.json --skipLibCheck",
    "lint": "eslint",
    "repack": "pnpm run build  && pnpm pack",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "ts-node": "ts-node",
    "test": "vitest run \"tests/**/*.test.{js,mjs,cjs,ts,mts,cts,jsx,tsx}\" --exclude \"tests/unit/**\" --exclude \"tests/integration/**\" --passWithNoTests",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ours": "vitest run tests/unit tests/integration",
    "test:all": "vitest run tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^22.19.18",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@effect/vitest": "^0.29.0",
    "vitest": "3.2.4"
  },
  "overrides": {
    "@cardano-sdk/core": "0.46.12",
    "@cardano-sdk/crypto": "0.4.5",
    "ip-address": "10.2.0"
  },
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@harmoniclabs/crypto": "^0.3.0",
    "@lucid-evolution/lucid": "^0.4.30",
    "@noble/hashes": "^1.8.0",
    "effect": "^3.21.2"
  }
}
