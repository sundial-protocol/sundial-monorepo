{
  "name": "midgard-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Management tools for Midgard L2",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @midgard-manager/* build",
    "dev": "pnpm --filter @midgard-manager/* dev",
    "lint": "pnpm --filter @midgard-manager/* lint",
    "clean": "pnpm --filter @midgard-manager/* clean",
    "start": "pnpm --filter @midgard-manager/cli start",
    "tx-generator": "pnpm --filter @midgard-manager/tx-generator start",
    "test": "pnpm --filter @midgard-manager/* test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint . --fix"
  },
  "dependencies": {
    "@lucid-evolution/lucid": "^0.4.23",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "effect": "^3.13.4",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "prettier": "^3.5.2",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@harmoniclabs/crypto": "0.2.5"
      }
    },
    "overrides": {
      "@cardano-sdk/core": "0.46.12",
      "@cardano-sdk/crypto": "0.4.5",
      "ip-address": "10.2.0"
    }
  }
}
