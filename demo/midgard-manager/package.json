{
  "name": "midgard-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Management tools for Midgard L2",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @midgard-manager/* build",
    "dev": "pnpm --filter @midgard-manager/* dev",
    "type-check:cli": "pnpm --filter @midgard-manager/cli run type-check",
    "type-check:tx-generator": "pnpm --filter @midgard-manager/tx-generator run type-check",
    "type-check": "pnpm run type-check:cli && pnpm run type-check:tx-generator",
    "lint": "pnpm --filter @midgard-manager/* lint",
    "clean": "pnpm --filter @midgard-manager/* clean",
    "start": "pnpm --filter @midgard-manager/cli start",
    "tx-generator": "pnpm --filter @midgard-manager/tx-generator start",
    "test": "pnpm --filter @midgard-manager/* test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint . --fix"
  },
  "dependencies": {
    "@lucid-evolution/lucid": "^0.4.30",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "effect": "^3.21.2",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "3.2.4"
  }
}
