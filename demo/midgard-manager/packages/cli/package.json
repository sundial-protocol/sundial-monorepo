{
  "name": "@midgard-manager/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "midgard": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup && pnpm copy-package-json",
    "build:ts": "tsup",
    "clean": "rimraf dist/*",
    "check": "tsc -b tsconfig.json",
    "type-check": "tsc -b tsconfig.json",    
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --max-warnings=0",
    "start": "node dist/bin.js",
    "copy-package-json": "node scripts/copy-package-json.mjs",
    "test": "echo 'No tests yet' && exit 0"
  },
  "dependencies": {
    "@anastasia-labs/cardano-multiplatform-lib-nodejs": "^6.0.2-3",
    "@effect/cli": "^0.75.1",
    "@effect/platform-node": "^0.106.0",
    "@inquirer/prompts": "^7.2.1",
    "@lucid-evolution/lucid": "^0.4.20",
    "@midgard-manager/tx-generator": "workspace:*",
    "@types/node-cron": "^3.0.11",
    "chalk": "^4.1.2",
    "effect": "^3.21.2",
    "node-cron": "^3.0.3",
    "ora-classic": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
